$C = "Common.ui";
// Chonbos Chemistry shared UI tokens (amber-on-slate identity). Imported by machine panels as
// $M = "../CC_Master.ui". Panel idiom (borrowed from HyProTech/Machinarium, re-authored): a bordered
// Group (Background:@PanelBorderColor; Padding:(Full:1)) wrapping a fill Group (Background:
// @PanelFillColor), with a header Label + 1px @PanelDividerColor divider + content. See
// docs/plans/2026-06-21-cc-smelter-ui-redo-plan.md.

// Panel chrome: dark-gray theme (replaces the old amber/brown). Two requested grays: darker #4f585d
// (card frame), lighter #6e7f87 (divider/accent); cards sit on a dark neutral-gray fill for contrast.
@PanelFillColor = #23282b(0.92);
@PanelBorderColor = #4f585d(1);
@PanelDividerColor = #6e7f87(1);

// Accents + text (light gray, replacing amber).
@Amber = #4f585d(1);
@AmberLite = #6e7f87(1);
@ValueText = #e6ebed(1);
@LabelText = #c2ccd0(1);

// Sizes measured from vanilla (Common.ui + real container pages: ItemRepair/Barter/EntitySpawn).
// Vanilla container item icons are 64px (DroppedItemSlot / Barter output slot); buttons 44 tall;
// content padding 17; section headers FontSize 15 uppercase; ProgressBar track wrapped in a 12px
// Group with the bar drawing fill+effect (EffectWidth 102 / Height 58 / Offset 74).
@ProcessColumnWidth = 404;
@StatusColumnWidth = 300;
@PanelGap = 12;
@ContentPad = 16;
@SlotSize = 64;
@SlotIconSize = 64;
@SlotSpacing = 6;
@ReqSlotSize = 32;
@BarHeight = 12;
@ButtonHeight = 44;
@HeaderFontSize = 15;
