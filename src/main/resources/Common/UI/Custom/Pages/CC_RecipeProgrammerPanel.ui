$C = "../Common.ui";
$M = "../CC_Master.ui";

// Chonbo's Chemistry: the Recipe Programmer bench panel (the recipe BROWSER, native crafting-bench look). A
// sibling of CC_CookerPanel.ui. Three columns: LEFT an ICON GRID (#RecipeGrid, an ItemGrid populated with the
// recipe outputs; SlotClicking -> select), MIDDLE a select pane (#SelectName + a #Count NumberField + a blue
// #AddToCard button), RIGHT the loaded card's program ICON GRID (#ProgramGrid, icon x count; double-click a
// slot to remove that entry) + #TakeCard.
//
// Mirrors vanilla EntitySpawnPage's mechanisms (machine button-bar + search + a #Count NumberField + a
// primary action button reading #Count.Value) and the ItemGrid SlotClicking/SlotIndex selection proven in
// HyProTech's AlloySmelterPage. The server (RecipeProgrammerPanelPage) sets #PanelTitle.TextSpans, drives the
// machine buttons (#MachineBtn*), the search field (#SearchInput, ValueChanged), the runtime #RecipeGrid.Slots
// (each slot click -> select that recipe), the select pane, the program grid (#ProgramGrid), and binds
// #AddToCard / #TakeCard.
//
// SCALE: #RecipeGrid is one ItemGrid (not cloned rows) with TopScrolling, so it scrolls at scale : the server
// now sets a slot for EVERY filtered recipe (no cap; the machine filter + search still narrow the list).

@PanelBorderColor = $M.@PanelBorderColor;
@PanelFillColor = $M.@PanelFillColor;
@PanelDividerColor = $M.@PanelDividerColor;
@ValueText = $M.@ValueText;
@LabelText = $M.@LabelText;
@ContentPad = $M.@ContentPad;
@ButtonHeight = $M.@ButtonHeight;
@HeaderFontSize = $M.@HeaderFontSize;

// Icon-grid slot sizing : 2x the original (80px slots, 4px gap) for a chunkier, more native recipe look.
@GridSlotSize = 80;
@GridSlotGap = 4;

$C.@PageOverlay {
  $C.@DecoratedContainer {
    Anchor: (Width: 900, Height: 520);

    // Title set from Java (#PanelTitle.TextSpans). Vanilla title style.
    #Title {
      Group {
        Label #PanelTitle {
          Style: (
            ...$C.@TitleStyle,
            HorizontalAlignment: Center
          );
          Padding: (Horizontal: 19);
          Text: "";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: @ContentPad);

      // --- Machine filter button-bar: one SecondaryTextButton per recipe-bearing machine. The server
      //     toggles each button's Style (active vs inactive) + scopes #RecipeList to that machine's pool. ---
      Group #MachineBar {
        Anchor: (Left: 0, Right: 0, Height: 30);
        LayoutMode: Left;

        $C.@SecondaryTextButton #MachineBtnCooker     { Text: "Cooker";     FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtnForge      { Text: "Forge";      FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtnCultivator { Text: "Cultivator"; FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtnAlembic    { Text: "Alembic";    FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtnAssembler  { Text: "Assembler";  FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtnOutfitter  { Text: "Outfitter";  FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtnSculptor   { Text: "Sculptor";   FlexWeight: 1; }
      }

      Group { Anchor: (Height: 10); }

      // --- The three columns: icon-grid browser (left) + select/count/add pane (middle) + program (right). ---
      Group {
        Anchor: (Left: 0, Right: 0);
        FlexWeight: 1;
        LayoutMode: Left;

        // LEFT: the recipe browser (search + capped ICON GRID of recipe outputs).
        Group #BrowserPanel {
          FlexWeight: 3;
          Background: @PanelBorderColor;
          Padding: (Full: 1);

          Group {
            Anchor: (Full: 0);
            Background: @PanelFillColor;
            LayoutMode: Top;
            Padding: (Top: 10, Left: 12, Right: 12, Bottom: 12);

            Label {
              Style: (FontSize: @HeaderFontSize, RenderBold: true, RenderUppercase: true, TextColor: @LabelText);
              Text: "Recipes";
            }
            Group { Anchor: (Height: 6); }
            Group { Anchor: (Height: 1); Background: @PanelDividerColor; }
            Group { Anchor: (Height: 8); }

            // Live search box : a FULL-WIDTH input spanning the recipes column with the standard recessed
            // dark input background. The $C.@TextField macro ALREADY carries Background: @InputBoxBackground
            // (Common/InputBox.png : the recessed look every Hytale search bar uses) and Height: 38; we only
            // set @Anchor (its supported full-width hook : Left/Right 0) + PlaceholderText. This is the exact
            // proven call form from PrefabBrowser.ui / InstanceListPage.ui's "$C.@TextField #SearchInput".
            // NOTE: no inline search-icon Decoration : Decoration is a CompactTextField property (what
            // $C.@HeaderSearch uses), NOT a plain TextField one; attaching it here fails document parse.
            // The id #SearchInput is kept (the page binds ValueChanged on it).
            $C.@TextField #SearchInput {
              @Anchor = (Left: 0, Right: 0);
              PlaceholderText: %server.customUI.searchPlaceholder;
            }
            Group { Anchor: (Height: 8); }

            // A plain "N recipes" count of the filtered list (server-set; no cap any more).
            Label #ListNote {
              Anchor: (Left: 0, Right: 0);
              Style: (FontSize: 12, TextColor: @LabelText);
              Text: "";
            }
            Group { Anchor: (Height: 4); }

            // The runtime-built recipe ICON GRID (uncapped : one slot per filtered recipe). Server sets
            // #RecipeGrid.Slots to ItemGridSlot[] of each recipe's primary output stack (icon + quantity); a
            // slot click fires SlotClicking (the client auto-injects SlotIndex). ShowScrollbar = scroll the
            // full filtered list (it is ONE ItemGrid, not cloned rows, so it scales).
            ItemGrid #RecipeGrid {
              Anchor: (Left: 0, Right: 0);
              FlexWeight: 1;
              SlotsPerRow: 3;
              AreItemsDraggable: false;
              ShowScrollbar: true;
              RenderItemQualityBackground: false;
              Style: (
                SlotSize: @GridSlotSize,
                SlotIconSize: @GridSlotSize,
                SlotSpacing: @GridSlotGap,
                SlotBackground: "../Common/BlockSelectorSlotBackground.png"
              );
            }
          }
        }

        Group { Anchor: (Width: @ContentPad); }

        // MIDDLE: the select pane : the selected recipe's output name, a count control, and Add To Card.
        Group #SelectPanel {
          FlexWeight: 2;
          Background: @PanelBorderColor;
          Padding: (Full: 1);

          Group {
            Anchor: (Full: 0);
            Background: @PanelFillColor;
            LayoutMode: Top;
            Padding: (Top: 10, Left: 12, Right: 12, Bottom: 12);

            Label {
              Style: (FontSize: @HeaderFontSize, RenderBold: true, RenderUppercase: true, TextColor: @LabelText);
              Text: "Selection";
            }
            Group { Anchor: (Height: 6); }
            Group { Anchor: (Height: 1); Background: @PanelDividerColor; }
            Group { Anchor: (Height: 10); }

            // The selected recipe's output display name (server-set; a prompt when nothing is selected).
            Label #SelectName {
              Anchor: (Left: 0, Right: 0);
              Style: (FontSize: 16, RenderBold: true, TextColor: @ValueText, Wrap: true);
              Text: "Select a recipe";
            }
            Group { Anchor: (Height: 10); }

            // The selected recipe's INPUT ingredients as a scrolling ICON GRID (Fuel stripped : CC machines
            // burn energy). Server sets #IngredientGrid.Slots to ItemGridSlot[] of each input stack; xN
            // required-quantity shows via DisplayItemQuantity. Cleared when nothing is selected. Scroll attrs
            // copied from #RecipeGrid; same @GridSlotSize (80px) as #RecipeGrid, 2 per row to fit the column.
            ItemGrid #IngredientGrid {
              Anchor: (Left: 0, Right: 0);
              FlexWeight: 1;
              SlotsPerRow: 2;
              AreItemsDraggable: false;
              ShowScrollbar: true;
              RenderItemQualityBackground: false;
              Style: (
                SlotSize: @GridSlotSize,
                SlotIconSize: @GridSlotSize,
                SlotSpacing: @GridSlotGap,
                SlotBackground: "../Common/BlockSelectorSlotBackground.png"
              );
            }
            Group { Anchor: (Height: 12); }

            // Count control. A smaller NumberField (0 = infinite) flanked by decrement/increment arrows. The
            // arrows read the LIVE #Count.Value and write back the clamped result (no server pending state);
            // the field stays directly editable. The hint below explains 0 = infinite.
            Group {
              Anchor: (Left: 0, Right: 0);
              LayoutMode: Left;

              Label {
                Anchor: (Width: 56);
                Text: "Count";
                Style: (FontSize: 13, TextColor: @LabelText, VerticalAlignment: Center);
              }

              $C.@SecondaryTextButton #CountDown {
                Anchor: (Width: 32, Height: @ButtonHeight);
                Text: "<";
              }

              $C.@NumberField #Count {
                @Anchor = (Left: 4, Width: 64, Right: 0);
                Format: (
                  MaxDecimalPlaces: 0,
                  Step: 1,
                  MinValue: 0,
                  MaxValue: 9999
                );
                Value: 0;
              }

              Group { Anchor: (Width: 4); }

              $C.@SecondaryTextButton #CountUp {
                Anchor: (Width: 32, Height: @ButtonHeight);
                Text: ">";
              }
            }
            Group { Anchor: (Height: 4); }

            Label {
              Anchor: (Left: 0, Right: 0);
              Style: (FontSize: 12, TextColor: @LabelText);
              Text: "0 = infinite";
            }
            Group { Anchor: (Height: 8); }

            // Select status line : shown ONLY for genuine errors (e.g. "No card loaded." / "Select a recipe
            // first."). The positive "added" feedback is intentionally not shown (the program grid updates
            // visibly). Server-set.
            Label #SelectStatus {
              Anchor: (Left: 0, Right: 0);
              Style: (FontSize: 12, TextColor: @LabelText, Wrap: true);
              Text: "";
            }
            Group { Anchor: (Height: 10); }

            // ADD TO CARD : the primary (blue) action button, panel-local at the BOTTOM of the select pane
            // (a normal full-width button like CC_CookerPanel's #PowerToggle). Server binds #AddToCard
            // (Activating + @Count). A real Anchor (Height) : never a bare FlexWeight.
            $C.@TextButton #AddToCard {
              @Anchor = (Left: 0, Right: 0, Height: @ButtonHeight);
              @Text = "Add To Card";
            }
          }
        }

        Group { Anchor: (Width: @ContentPad); }

        // RIGHT: the loaded card's current program (read-only entries) + Take Card. The inner fill group holds
        // TWO OVERLAPPING full-area children (both Anchor: (Full: 0), so they occupy the same space, the way
        // vanilla overlays): #ProgramContent (the real program UI) and #ProgramEmpty (a dim-grey "No Card
        // Loaded" cover). The server toggles their .Visible : content when a card is loaded, the cover when no
        // card is inserted. Neither is a bare FlexWeight-only group : each has an explicit Anchor + children.
        Group #ProgramPanel {
          FlexWeight: 2;
          Background: @PanelBorderColor;
          Padding: (Full: 1);

          Group {
            Anchor: (Full: 0);
            Background: @PanelFillColor;

            // The real program content (header + status + grid + take-card). Hidden when no card is loaded.
            Group #ProgramContent {
              Anchor: (Full: 0);
              LayoutMode: Top;
              Padding: (Top: 10, Left: 12, Right: 12, Bottom: 12);

              Label {
                Style: (FontSize: @HeaderFontSize, RenderBold: true, RenderUppercase: true, TextColor: @LabelText);
                Text: "Program";
              }
              Group { Anchor: (Height: 6); }
              Group { Anchor: (Height: 1); Background: @PanelDividerColor; }
              Group { Anchor: (Height: 8); }

              // Card status line ("Blank card (no program)." / "N entries"). Server-set.
              Label #ProgramText {
                Anchor: (Left: 0, Right: 0);
                Style: (FontSize: 13, TextColor: @ValueText, Wrap: true);
                Text: "No card loaded.";
              }
              Group { Anchor: (Height: 8); }

              // The current program entries as an ICON GRID (one slot per entry = the recipe's primary output;
              // finite entries show "icon xN", infinite entries show a bare icon). DisplayItemQuantity renders
              // the finite counts. Double-clicking a slot fires SlotDoubleClicking (the client auto-injects
              // SlotIndex, same as SlotClicking) -> the server removes that entry. Attrs match #RecipeGrid
              // (same @GridSlotSize, 2 per row to fit the column).
              ItemGrid #ProgramGrid {
                Anchor: (Left: 0, Right: 0);
                FlexWeight: 1;
                SlotsPerRow: 2;
                AreItemsDraggable: false;
                ShowScrollbar: true;
                RenderItemQualityBackground: false;
                Style: (
                  SlotSize: @GridSlotSize,
                  SlotIconSize: @GridSlotSize,
                  SlotSpacing: @GridSlotGap,
                  SlotBackground: "../Common/BlockSelectorSlotBackground.png"
                );
              }
              Group { Anchor: (Height: 10); }

              // TAKE CARD : panel-local at the BOTTOM of the program pane. Returns the loaded card to the
              // player (clears the slot). Server binds #TakeCard (Activating). A real Anchor (Height) : never
              // a bare FlexWeight.
              $C.@CancelTextButton #TakeCard {
                Anchor: (Left: 0, Right: 0, Height: @ButtonHeight);
                Text: "Take Card";
              }
            }

            // EMPTY-STATE COVER : a dim-grey full-area overlay with a BIG centered "No Card Loaded" message,
            // shown (server toggles .Visible) when no card is inserted. Greys out the whole program section.
            // The alpha-color form #000000(0.5) is the proven vanilla overlay form (e.g. EntitySpawnPage).
            Group #ProgramEmpty {
              Anchor: (Full: 0);
              Background: #000000(0.5);

              Label #ProgramEmptyText {
                Anchor: (Full: 0);
                Style: (
                  FontSize: 24,
                  RenderBold: true,
                  HorizontalAlignment: Center,
                  VerticalAlignment: Center,
                  TextColor: @LabelText
                );
                Text: "No Card Loaded";
              }
            }
          }
        }
      }
    }
  }
}

$C.@BackButton {}
