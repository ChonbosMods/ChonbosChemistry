$C = "../Common.ui";
$M = "../CC_Master.ui";

// Chonbo's Chemistry: the Recipe Programmer bench panel (Phase 3.2 : the recipe BROWSER). A sibling of
// CC_CookerPanel.ui. Mirrors vanilla EntitySpawnPage's mechanisms (machine button-bar + search +
// TopScrolling runtime-built list + click-to-add). The server (RecipeProgrammerPanelPage) sets
// #PanelTitle.TextSpans, drives the machine-filter buttons (#MachineBtn_*), the search field
// (#SearchInput, ValueChanged), the runtime #RecipeList rows (each Activating -> add to the card's
// program), the read-only #ProgramText, the "showing N of M" #ListNote, and binds #TakeCard (Activating).
//
// SCALE: #RecipeList is filtered + capped server-side (RecipeBrowse.filterAndCap) BEFORE any row is
// appended : the Sculptor's ~911-recipe pool is never rendered whole (see RecipeBrowse.ROW_CAP).

@PanelBorderColor = $M.@PanelBorderColor;
@PanelFillColor = $M.@PanelFillColor;
@PanelDividerColor = $M.@PanelDividerColor;
@ValueText = $M.@ValueText;
@LabelText = $M.@LabelText;
@ContentPad = $M.@ContentPad;
@ButtonHeight = $M.@ButtonHeight;
@HeaderFontSize = $M.@HeaderFontSize;

$C.@PageOverlay {
  $C.@DecoratedContainer {
    Anchor: (Width: 640, Height: 480);

    // Title set from Java (#PanelTitle.TextSpans). Vanilla title style.
    #Title {
      Group {
        Label #PanelTitle {
          Style: (
            ...$C.@TitleStyle,
            HorizontalAlignment: Center
          );
          Padding: (Horizontal: 19);
          Text: "";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: @ContentPad);

      // --- Machine filter button-bar: one SecondaryTextButton per recipe-bearing machine. The server
      //     toggles each button's Style (active vs inactive) + scopes #RecipeList to that machine's pool. ---
      Group #MachineBar {
        Anchor: (Left: 0, Right: 0, Height: 30);
        LayoutMode: Left;

        $C.@SecondaryTextButton #MachineBtn_Cooker     { Text: "Cooker";     FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtn_Forge      { Text: "Forge";      FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtn_Cultivator { Text: "Cultivator"; FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtn_Alembic    { Text: "Alembic";    FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtn_Assembler  { Text: "Assembler";  FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtn_Outfitter  { Text: "Outfitter";  FlexWeight: 1; }
        Group { Anchor: (Width: 4); }
        $C.@SecondaryTextButton #MachineBtn_Sculptor   { Text: "Sculptor";   FlexWeight: 1; }
      }

      Group { Anchor: (Height: 10); }

      // --- The two columns: a filtered/capped recipe browser (left) + the read-only program (right). ---
      Group {
        Anchor: (Left: 0, Right: 0);
        FlexWeight: 1;
        LayoutMode: Left;

        // LEFT: the recipe browser (search + scrolling, capped recipe rows).
        Group #BrowserPanel {
          FlexWeight: 3;
          Background: @PanelBorderColor;
          Padding: (Full: 1);

          Group {
            Anchor: (Full: 0);
            Background: @PanelFillColor;
            LayoutMode: Top;
            Padding: (Top: 10, Left: 12, Right: 12, Bottom: 12);

            Label {
              Style: (FontSize: @HeaderFontSize, RenderBold: true, RenderUppercase: true, TextColor: @LabelText);
              Text: "Recipes";
            }
            Group { Anchor: (Height: 6); }
            Group { Anchor: (Height: 1); Background: @PanelDividerColor; }
            Group { Anchor: (Height: 8); }

            // Live search box. Server binds #SearchInput (ValueChanged -> @SearchQuery). The CompactTextField
            // id (#SearchInput) is fixed by the $C.@HeaderSearch macro; we re-anchor it to fill the column.
            Group #SearchBar {
              Anchor: (Left: 0, Right: 0, Height: 30);
              $C.@HeaderSearch {
                Anchor: (Left: 0, Right: 0);
              }
            }
            Group { Anchor: (Height: 8); }

            // "showing N of M (refine search)" : server-set, only visible when the list is capped.
            Label #ListNote {
              Anchor: (Left: 0, Right: 0);
              Style: (FontSize: 12, TextColor: @LabelText);
              Text: "";
              Visible: false;
            }
            Group { Anchor: (Height: 4); }

            // The runtime-built, capped recipe list. Server clears + appends Common/TextButton.ui rows, each
            // bound Activating -> add the recipe to the card's program. TopScrolling = a scrollbar past the cap.
            Group #RecipeList {
              Anchor: (Left: 0, Right: 0);
              FlexWeight: 1;
              LayoutMode: TopScrolling;
              ScrollbarStyle: $C.@DefaultScrollbarStyle;
            }
          }
        }

        Group { Anchor: (Width: @ContentPad); }

        // RIGHT: the loaded card's current program (read-only entries) + Take Card.
        Group #ProgramPanel {
          FlexWeight: 2;
          Background: @PanelBorderColor;
          Padding: (Full: 1);

          Group {
            Anchor: (Full: 0);
            Background: @PanelFillColor;
            LayoutMode: Top;
            Padding: (Top: 10, Left: 12, Right: 12, Bottom: 12);

            Label {
              Style: (FontSize: @HeaderFontSize, RenderBold: true, RenderUppercase: true, TextColor: @LabelText);
              Text: "Program";
            }
            Group { Anchor: (Height: 6); }
            Group { Anchor: (Height: 1); Background: @PanelDividerColor; }
            Group { Anchor: (Height: 8); }

            // Card status line ("No card loaded." / "N entries"). Server-set.
            Label #ProgramText {
              Anchor: (Left: 0, Right: 0);
              Style: (FontSize: 13, TextColor: @ValueText, Wrap: true);
              Text: "No card loaded.";
            }
            Group { Anchor: (Height: 8); }

            // The current program entries (one read-only row each). Server clears + appends rows.
            Group #ProgramList {
              Anchor: (Left: 0, Right: 0);
              FlexWeight: 1;
              LayoutMode: TopScrolling;
              ScrollbarStyle: $C.@DefaultScrollbarStyle;
            }
            Group { Anchor: (Height: 10); }

            // Return the loaded card to the player (clears the slot). Server binds #TakeCard (Activating).
            $C.@CancelTextButton #TakeCard {
              Anchor: (Left: 0, Right: 0, Height: @ButtonHeight);
              Text: "Take Card";
            }
          }
        }
      }
    }
  }
}

$C.@BackButton {}
