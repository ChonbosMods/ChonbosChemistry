$C = "../Common.ui";

// Chonbo's Chemistry: machine / tank block GUI (snapshot v1).
// Mirrors the proven Natural20 page structure (only @PageOverlay + @Container are used there):
// a framed container with a #Content column of plain Label rows. The server populates the
// #-selectors below from the block's MachineBlockState / TankBlockState component
// (see MachinePanelPage#build). Gauges are text readouts (Nat20 uses no @ProgressBar).
$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 440, Height: 320);

  #Content {
    LayoutMode: Top;
    Padding: (Left: 18, Right: 18, Top: 14, Bottom: 14);

    Label #BlockTitle {
      Text: "";
      Anchor: (Height: 30);
      Padding: (Bottom: 10);
      Style: (TextColor: #ffd700(1), FontSize: 20, RenderBold: true);
    }

    Label #EnergyLabel {
      Visible: false;
      Text: "";
      Anchor: (Height: 22);
      Padding: (Bottom: 6);
      Style: (TextColor: #ffd54a(1), FontSize: 15);
    }

    Label #FluidLabel {
      Visible: false;
      Text: "";
      Anchor: (Height: 22);
      Padding: (Bottom: 6);
      Style: (TextColor: #7ab8ff(1), FontSize: 15);
    }

    Label #GasLabel {
      Visible: false;
      Text: "";
      Anchor: (Height: 22);
      Padding: (Bottom: 6);
      Style: (TextColor: #b8e0c0(1), FontSize: 15);
    }

    Label #ItemLabel {
      Visible: false;
      Text: "";
      Anchor: (Height: 22);
      Padding: (Bottom: 6);
      Style: (TextColor: #d0d4de(1), FontSize: 15);
    }

    Label #EmptyLabel {
      Visible: false;
      Text: "";
      Anchor: (Height: 22);
      Padding: (Top: 8);
      Style: (TextColor: #778899(1), FontSize: 14);
    }
  }
}
