$C = "../Common.ui";
$M = "../CC_Master.ui";

// Chonbo's Chemistry: the CC COOKER panel. Sibling of CC_BenchMachinePanel.ui (Smelter/Reclaimer) but the
// Cooker is an autonomous crafter that owns its own containers + an inserted recipe-card slot (no held vanilla
// bench). Same two-column vanilla-measured layout (STATUS/controls LEFT, PROCESSING I/O RIGHT) with one
// addition: a single-slot #CardSlot for the recipe card, in the left column under the controls.
//
// See docs/research/2026-06-21-vanilla-ui-measurements.md for sizing. Bars use the recolored fills shipped in
// Common/UI/Custom/CC/ (energy = #4bfcce, smelting = #aa7c4a). Server (CookerPanelPage) sets #ProgressBar.Value
// / #PowerBar.Value (0..1), grid Slots, and the #CardSlot item. Texture paths use ../ (resolved relative to
// THIS file in Pages/). #UpgradePanel is built but hidden (Visible:false) until Phase 2. The #CardSlot is now
// INTERACTIVE (AreItemsDraggable: true + a Dropped binding): drag any inventory item onto it to load it as the
// card, click the filled slot to take it back. This proves the inventory<->slot drag-and-drop loop.

@PanelBorderColor = $M.@PanelBorderColor;
@PanelFillColor = $M.@PanelFillColor;
@PanelDividerColor = $M.@PanelDividerColor;
@ValueText = $M.@ValueText;
@LabelText = $M.@LabelText;
// Cooker override: wider than the shared bench column. The Cooker's held-ingredients scroll list (204px) + 2x2
// output (140px) would crush the center to ~6px on the shared 404 width; 530 restores a ~130px progress bar
// (the same size as the Smelter's center bar).
@ProcessColumnWidth = 530;
@StatusColumnWidth = $M.@StatusColumnWidth;
@PanelGap = $M.@PanelGap;
@ContentPad = $M.@ContentPad;
@SlotSize = $M.@SlotSize;
@SlotIconSize = $M.@SlotIconSize;
@SlotSpacing = $M.@SlotSpacing;
@BarHeight = $M.@BarHeight;
@ButtonHeight = $M.@ButtonHeight;
@HeaderFontSize = $M.@HeaderFontSize;

$C.@PageOverlay {
  $C.@DecoratedContainer {
    Anchor: (Width: 920, Height: 460);

    // Title set from Java (#PanelTitle.TextSpans). Vanilla title style.
    #Title {
      Group {
        Label #PanelTitle {
          Style: (
            ...$C.@TitleStyle,
            HorizontalAlignment: Center
          );
          Padding: (Horizontal: 19);
          Text: "";
        }
      }
    }

    #Content {
      LayoutMode: Left;
      Padding: (Full: @ContentPad);

      // ---- Left column: status + controls + recipe card + upgrade ----
      Group #StatusColumn {
        Anchor: (Width: @StatusColumnWidth);
        LayoutMode: Top;

        Group #StatusPanel {
          Anchor: (Left: 0, Right: 0);
          Background: @PanelBorderColor;
          Padding: (Full: 1);

          Group {
            Anchor: (Full: 0);
            Background: @PanelFillColor;
            LayoutMode: Top;
            Padding: (Top: 10, Left: 14, Right: 14, Bottom: 12);

            Label #TierText {
              Style: (FontSize: 18, RenderBold: true, TextColor: @ValueText);
              Text: "Tier: 0";
            }
            Group { Anchor: (Height: 6); }
            Group { Anchor: (Height: 1); Background: @PanelDividerColor; }
            Group { Anchor: (Height: 12); }

            Label #EnergyText {
              Anchor: (Left: 0, Right: 0);
              Style: (FontSize: 14, TextColor: @LabelText);
              Text: "Energy: 0 / 0";
            }
            Group { Anchor: (Height: 8); }

            // Energy bar: teal #4bfcce fill (recolored, shipped in CC/).
            Group {
              Anchor: (Left: 0, Right: 0, Height: @BarHeight);
              Background: "../Common/ProgressBar.png";

              ProgressBar #PowerBar {
                Anchor: (Full: 0);
                BarTexturePath: "../CC/ProgressBarFill_Energy.png";
                EffectTexturePath: "../Common/ProgressBarEffect.png";
                EffectWidth: 102;
                EffectHeight: 58;
                EffectOffset: 74;
                Value: 0.0;
              }
            }
            Group { Anchor: (Height: 12); }

            Label #StatusText {
              Style: (FontSize: 14, TextColor: @LabelText);
              Text: "Status: On";
            }
            Group { Anchor: (Height: 12); }

            // Recipe card: single INTERACTIVE slot. The player drags any item from their inventory onto it to
            // insert it as the card (server's #CardSlot Dropped binding -> CookerPanelPage.handleDataEvent moves
            // exactly one item from the inventory into node.card()); clicking the filled slot ejects it back to
            // the inventory. Mirrors vanilla EntitySpawnPage's #ItemMaterialSlot (a plain droppable ItemGrid +
            // a HitTestVisible:false drop-hint icon child shown only while empty). Server sets #CardSlot.Slots.
            Group {
              LayoutMode: Left;

              Group {
                Anchor: (Width: 72);

                ItemGrid #CardSlot {
                  Anchor: (Full: 0);
                  Style: ItemGridStyle(SlotSize: @SlotSize, SlotIconSize: @SlotIconSize, SlotSpacing: @SlotSpacing, SlotBackground: "../Common/BlockSelectorSlotBackground.png");
                  SlotsPerRow: 1;
                  AreItemsDraggable: true;
                  RenderItemQualityBackground: true;
                }

                // Drop-hint icon centered over the slot; only shown while the slot is empty (server toggles
                // #CardDropHint.Visible). HitTestVisible:false so it never swallows the drop/click on the slot.
                Group #CardDropHint {
                  Anchor: (Width: 24, Height: 24, Horizontal: 0, Vertical: 0);
                  Background: "../Common/BlockSelectorSlotDropIcon.png";
                  HitTestVisible: false;
                }
              }

              Group { Anchor: (Width: 12); }

              Group {
                FlexWeight: 1;
                LayoutMode: Top;
                Padding: (Top: 22);

                Label {
                  Anchor: (Left: 0, Right: 0);
                  Style: (FontSize: 13, TextColor: @LabelText);
                  Text: "Recipe Card";
                }
              }
            }
            Group { Anchor: (Height: 14); }

            // Button shows the action (mode to switch TO): when ON it reads "Turn Off". Server sets text.
            $C.@SecondaryTextButton #PowerToggle {
              Anchor: (Left: 0, Right: 0, Height: @ButtonHeight);
              Text: "Turn Off";
            }
            Group { Anchor: (Height: 8); }

            $C.@CancelTextButton #EjectBtn {
              Anchor: (Left: 0, Right: 0, Height: @ButtonHeight);
              Text: "Eject";
            }
          }
        }

        Group { Anchor: (Height: @PanelGap); }

        // Phase 2: functional upgrade panel (hidden until wired).
        Group #UpgradePanel {
          Anchor: (Left: 0, Right: 0);
          Background: @PanelBorderColor;
          Padding: (Full: 1);
          Visible: false;

          Group {
            Anchor: (Full: 0);
            Background: @PanelFillColor;
            LayoutMode: Top;
            Padding: (Top: 10, Left: 14, Right: 14, Bottom: 12);

            Label #NextTierText {
              Style: (FontSize: @HeaderFontSize, RenderBold: true, RenderUppercase: true, TextColor: @LabelText);
              Text: "Next Tier";
            }
            Group { Anchor: (Height: 6); }
            Group { Anchor: (Height: 1); Background: @PanelDividerColor; }
            Group { Anchor: (Height: 12); }

            Label #UpgradeReqText {
              Anchor: (Left: 0, Right: 0);
              Style: (FontSize: 13, TextColor: @LabelText, Wrap: true);
              Text: "";
            }
            Group { Anchor: (Height: 10); }

            $C.@TextButton #UpgradeBtn {
              Anchor: (Left: 0, Right: 0, Height: @ButtonHeight);
              Text: "Upgrade";
            }
          }
        }

        Group { Anchor: (Height: @PanelGap); }

        // ---- PROBE: live player-inventory grids ----
        // These ItemGrids are bound to the player's LIVE inventory via the native client-side element property
        // InventorySectionId (NOT a server-pushed .Slots list): -9 = backpack, -1 = hotbar (engine constants
        // Inventory.BACKPACK_SECTION_ID / HOTBAR_SECTION_ID). The probe asks whether the client renders the
        // player's real, draggable items here so the player has a DRAG SOURCE for the #CardSlot above (which
        // otherwise has no source behind an Interact-F machine panel : the player's own inventory UI is hidden).
        // We set InventorySectionId BOTH declaratively here AND at runtime from Java (CookerPanelPage.applyState
        // via commandBuilder.set(int overload)) so the probe maximizes the chance one path works. The server
        // does NOT push .Slots to these grids : the section binding is supposed to populate them live. If the
        // declarative property is ignored by the client the grids render empty (and the Java set is the fallback).
        Group #PlayerInvPanel {
          Anchor: (Left: 0, Right: 0);
          Background: @PanelBorderColor;
          Padding: (Full: 1);

          Group {
            Anchor: (Full: 0);
            Background: @PanelFillColor;
            LayoutMode: Top;
            Padding: (Top: 10, Left: 14, Right: 14, Bottom: 12);

            Label {
              Style: (FontSize: @HeaderFontSize, RenderBold: true, RenderUppercase: true, TextColor: @LabelText);
              Text: "Inventory (probe)";
            }
            Group { Anchor: (Height: 6); }
            Group { Anchor: (Height: 1); Background: @PanelDividerColor; }
            Group { Anchor: (Height: 12); }

            // Backpack (section -9). Draggable so the player can drag an item out onto #CardSlot.
            ItemGrid #PlayerBackpack {
              Anchor: (Left: 0, Right: 0);
              Style: ItemGridStyle(SlotSize: @SlotSize, SlotIconSize: @SlotIconSize, SlotSpacing: @SlotSpacing, SlotBackground: "../Common/BlockSelectorSlotBackground.png");
              SlotsPerRow: 9;
              AreItemsDraggable: true;
              RenderItemQualityBackground: true;
              InventorySectionId: -9;
            }

            Group { Anchor: (Height: 8); }

            // Hotbar (section -1).
            ItemGrid #PlayerHotbar {
              Anchor: (Left: 0, Right: 0);
              Style: ItemGridStyle(SlotSize: @SlotSize, SlotIconSize: @SlotIconSize, SlotSpacing: @SlotSpacing, SlotBackground: "../Common/BlockSelectorSlotBackground.png");
              SlotsPerRow: 9;
              AreItemsDraggable: true;
              RenderItemQualityBackground: true;
              InventorySectionId: -1;
            }
          }
        }
      }

      Group { Anchor: (Width: @PanelGap); }

      // ---- Right column: the I/O / processing block (native Hytale puts processing on the right) ----
      Group #ProcessColumn {
        Anchor: (Width: @ProcessColumnWidth);
        LayoutMode: Top;

        Group #ProcessPanel {
          Anchor: (Left: 0, Right: 0);
          Background: @PanelBorderColor;
          Padding: (Full: 1);

          Group {
            Anchor: (Full: 0);
            Background: @PanelFillColor;
            LayoutMode: Top;
            Padding: (Top: 10, Left: 14, Right: 14, Bottom: 12);

            Label {
              Style: (FontSize: @HeaderFontSize, RenderBold: true, RenderUppercase: true, TextColor: @LabelText);
              Text: "Crafting";
            }
            Group { Anchor: (Height: 6); }
            Group { Anchor: (Height: 1); Background: @PanelDividerColor; }
            Group { Anchor: (Height: 14); }

            // Held ingredients (the active craft's pulled stacks) | progress bar (centered) | output slots.
            Group #IoRow {
              LayoutMode: Left;
              Anchor: (Left: 0, Right: 0, Height: 220);

              // Held ingredients: a vertically-scrolling viewport (TopScrolling + vanilla scrollbar style)
              // wrapping the read-only #InputGrid. Empty while idle; the grid grows downward as ingredients
              // are pulled and scrolls within this fixed 200px height instead of overflowing the I/O row.
              Group #HeldScroll {
                Anchor: (Width: 204, Height: 200);
                LayoutMode: TopScrolling;
                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                ItemGrid #InputGrid {
                  Style: ItemGridStyle(SlotSize: @SlotSize, SlotIconSize: @SlotIconSize, SlotSpacing: @SlotSpacing, SlotBackground: "../Common/BlockSelectorSlotBackground.png");
                  SlotsPerRow: 3;
                  AreItemsDraggable: false;
                  RenderItemQualityBackground: true;
                  Anchor: (Left: 0, Right: 0);
                }
              }

              Group { Anchor: (Width: 12); }

              // Center: crafting bar + status text, vertically centered in the I/O row.
              Group {
                FlexWeight: 1;
                LayoutMode: Top;
                Padding: (Top: 90);

                // Crafting bar: native progress orange #aa7c4a fill (recolored, shipped in CC/).
                Group {
                  Anchor: (Left: 0, Right: 0, Height: @BarHeight);
                  Background: "../Common/ProgressBar.png";

                  ProgressBar #ProgressBar {
                    Anchor: (Full: 0);
                    BarTexturePath: "../CC/ProgressBarFill_Smelt.png";
                    EffectTexturePath: "../Common/ProgressBarEffect.png";
                    EffectWidth: 102;
                    EffectHeight: 58;
                    EffectOffset: 74;
                    Value: 0.0;
                  }
                }

                Group { Anchor: (Height: 10); }

                Label #ProgressText {
                  Anchor: (Left: 0, Right: 0);
                  Style: (FontSize: 14, TextColor: @ValueText, HorizontalAlignment: Center);
                  Text: "Idle";
                }
              }

              Group { Anchor: (Width: 12); }

              ItemGrid #OutputGrid {
                Style: ItemGridStyle(SlotSize: @SlotSize, SlotIconSize: @SlotIconSize, SlotSpacing: @SlotSpacing, SlotBackground: "../Common/BlockSelectorSlotBackground.png");
                SlotsPerRow: 2;
                AreItemsDraggable: false;
                RenderItemQualityBackground: true;
                Anchor: (Width: 140);
              }
            }
          }
        }
      }
    }
  }
}

$C.@BackButton {}
